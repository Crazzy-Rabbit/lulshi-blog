---
import type { InferGetStaticPropsType, GetStaticPaths } from "astro";
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";

import BlogPost from "@/layouts/BlogPost";

import { filterByLanguage, getSlugFromCollectionEntry } from "@/utils";
import { getSupportedLanguages, type SupportedLanguage } from "src/utils/i18n";

export const getStaticPaths = (async () => {
  const projectEntries = await getCollection("project", ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true;
  });

  return getSupportedLanguages().flatMap((lang) => {
    const filteredByLanguage = filterByLanguage(
      projectEntries,
      lang as SupportedLanguage,
    );

    return filteredByLanguage.map((post) => {
      const slug = getSlugFromCollectionEntry(
        post as CollectionEntry<"project">,
      );

      return {
        params: { lang, slug },
        props: { post },
      };
    });
  });
}) satisfies GetStaticPaths;

export type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { post } = Astro.props;

console.log("[project route] id =", post.id);
console.log("[project route] collection =", post.collection);
console.log("[project route] title =", post.data.title);
console.log("[project route] tags =", post.data.tags);
console.log("[project route] series =", post.data.series);
console.log("[project route] heroImage =", post.data.heroImage);

const { Content } = await (post as CollectionEntry<"project">).render();
---

<BlogPost post={post as CollectionEntry<"blog" | "project">}>
  <Content />
</BlogPost>